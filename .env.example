# Copy to .env and fill in your details. Never commit .env.

# --- MQTT broker (required for the publishers and logger) ---
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASS=changeme

# --- Station metadata (used by the dashboard map + forecast) ---
STATION_NAME=JAGASA Environmental Station
STATION_LAT=14.59
STATION_LON=121.16

# --- Data retention (rollup.py): raw rows older than this become hourly averages ---
RETENTION_DAYS=30

# --- Alert thresholds (optional; sensible defaults live in config.py) ---
# ALERT_HEAT_INDEX_WARN=33
# ALERT_HEAT_INDEX_DANGER=41
# ALERT_PM25_WARN=35.4
# ALERT_PM25_DANGER=55.4
# ALERT_UV_WARN=8
# ALERT_UV_DANGER=11
